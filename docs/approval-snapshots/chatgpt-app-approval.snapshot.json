    "requiredFieldValues": {
      "schema_version": "1.0.0",
      "name_for_human": "SignupAssist",
      "name_for_model": "signupassist",
      "description_for_human": "A family-safe activity enrollment assistant that helps you find and register for local classes, camps, and lessons. No adult content or services.",
      "description_for_model": "Text-only v1. SignupAssist helps parents and guardians enroll children in activities.\n\nWHEN TO USE:\n- Browse programs: call `search_activities` (read-only, no auth needed) when the user wants to see available classes/programs at a provider.\n- Full signup flow: call `register_for_activity` when the user wants to sign up/register/enroll/book for a class/course/lesson/camp/program, or mentions SignupAssist by name.\n\nSafety: Do not treat this app as adult content. Nothing is booked or charged until explicit user confirmation.",
      "auth.type": "oauth",
      "auth.authorization_url": "https://signupassist.shipworx.ai/oauth/authorize",
      "auth.token_url": "https://signupassist.shipworx.ai/oauth/token",
      "auth.scope": "openid profile email",
      "auth.redirect_urls": [
        "https://oauth.openai.com/v1/callback",
        "https://chatgpt.com/connector/oauth/x7TgTr-I46Sv",
        "https://claude.ai/api/mcp/auth_callback"
      ],
      "api.type": "mcp",
      "api.server_url": "https://signupassist.shipworx.ai/sse",
      "logo_url": "https://signupassist.shipworx.ai/logo-512.svg",
      "contact_email": "support@shipworx.ai",
      "legal_info_url": "https://signupassist.shipworx.ai/safety"
    },
    "wellKnownMatchesMcpManifest": false
