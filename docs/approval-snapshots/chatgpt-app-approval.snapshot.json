    "requiredFieldValues": {
      "schema_version": "1.0.0",
      "name_for_human": "SignupAssist",
      "name_for_model": "signupassist",
      "description_for_human": "A family-safe, parent-controlled assistant for adults managing child-safe youth activity signups. Helps parents and guardians find and register for classes, camps, and lessons. No adult-only services.",
      "description_for_model": "Text-only v1. SignupAssist is for adult parents and guardians managing child-safe youth activity enrollment. Children do not use this app directly.\n\nWHEN TO USE:\n- Browse youth programs: call `search_activities` (read-only, no auth needed) when the user wants to see available child-safe classes/programs at a supported provider.\n- Parent/guardian signup flow: call `register_for_activity` when the adult user wants to sign up/register/enroll/book a child, teen, or minor for a youth class/course/lesson/camp/program, or mentions SignupAssist by name.\n\nDO NOT USE for adult-only activities, dating, gambling, adult content, financial/investment services, or requests where the participant is an adult. Do not treat this app as adult content.\n\nPrivacy/COPPA boundary: do not ask for or process personal information about children under 13 in ChatGPT. General age/grade can be used for search. If a provider requires under-13 personal details, pause and direct the parent/guardian to an appropriate provider or non-ChatGPT flow.\n\nSafety: Nothing is booked or charged until explicit user confirmation from the adult parent or guardian.",
      "auth.type": "oauth",
      "auth.authorization_url": "https://signupassist.shipworx.ai/oauth/authorize",
      "auth.token_url": "https://signupassist.shipworx.ai/oauth/token",
      "auth.scope": "openid profile email",
      "auth.redirect_urls": [
        "https://oauth.openai.com/v1/callback",
        "https://chatgpt.com/connector/oauth/x7TgTr-I46Sv",
        "https://claude.ai/api/mcp/auth_callback"
      ],
      "api.type": "mcp",
      "api.server_url": "https://signupassist.shipworx.ai/sse",
      "logo_url": "https://signupassist.shipworx.ai/logo-512.svg",
      "contact_email": "support@shipworx.ai",
      "legal_info_url": "https://signupassist.shipworx.ai/safety"
    },
    "wellKnownMatchesMcpManifest": false
  },
