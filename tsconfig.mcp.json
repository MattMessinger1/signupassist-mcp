{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["node"],

    // Ensure stable dist output paths across environments (Docker/Railway vs local).
    // Without this, TypeScript may infer rootDir as "mcp_server" (since mcp/ has no TS),
    // producing dist/index.js instead of dist/mcp_server/index.js, which breaks Docker CMD.
    "rootDir": ".",

    // 🚀 Major speedup with incremental compilation
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",

    "outDir": "./dist"
  },
  "include": ["mcp_server", "mcp"],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.md",
    "mcp_server/tests/**",
    "mcp_server/types/**",
    "mcp_server/ai/AIOrchestrator.ts",
    "mcp_server/agent/**",
    "scripts/testAIOrchestrator.ts"
  ]
}
