# SignupAssist environment template
# Source of truth: scripts/envRegistry.ts
# Generate target-specific ignored files with:
#   npm run env:write -- --target=railway-web --out=.env.railway-web.generated
#   npm run env:write -- --target=railway-worker --out=.env.railway-worker.generated
#   npm run env:write -- --target=supabase-functions --out=.env.supabase.generated


# Frontend MCP
# Public MCP server base URL used by the Vite app and chat harness.
VITE_MCP_BASE_URL=https://your-web-service.up.railway.app
# MCP access token exposed to local/test frontend builds that call protected MCP endpoints.
# secret
VITE_MCP_ACCESS_TOKEN=dev-mcp-token

# MCP runtime
# Server-to-server MCP base URL for orchestrator calls, Supabase functions, and smoke scripts.
MCP_SERVER_URL=https://your-web-service.up.railway.app
# Bearer token accepted by protected MCP endpoints and used by smoke scripts.
# secret
MCP_ACCESS_TOKEN=your-mcp-access-token

# Supabase
# Supabase project URL.
SUPABASE_URL=https://your-project.supabase.co
# Supabase anon key for public client and Edge Function user-token verification.
# secret
SUPABASE_ANON_KEY=your-supabase-anon-key
# Supabase project URL exposed to the Vite frontend.
VITE_SUPABASE_URL=https://your-project.supabase.co
# Supabase publishable key exposed to the Vite frontend.
# secret
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Supabase service role key for server, worker, and privileged Edge Function work.
# secret
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Comma-separated public Edge Functions checked by the Supabase smoke script.
SUPABASE_SMOKE_FUNCTIONS=get-user-location

# Billing
# Stripe secret key for success-fee and autopilot subscription Edge Functions.
# secret
STRIPE_SECRET_KEY=sk_test_your_key_here
# Stripe webhook signing secret for subscription status updates.
# secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Optional Stripe Price ID for the $9/month SignupAssist Autopilot plan.
STRIPE_AUTOPILOT_PRICE_ID=price_signupassist_autopilot_monthly
# Public app URL used by Stripe subscription checkout redirects.
PUBLIC_SITE_URL=http://localhost:8080

# Providers
# Bookeo API key for catalog, booking, sync, and scheduled worker flows.
# secret
BOOKEO_API_KEY=your-bookeo-api-key
# Bookeo secret key for catalog, booking, sync, and scheduled worker flows.
# secret
BOOKEO_SECRET_KEY=your-bookeo-secret-key
# Active Network search API key for ActiveNet provider sync/search.
# secret
ACTIVE_SEARCH_API_V2_KEY=your-active-search-api-v2-key
# ActiveNet US API key.
# secret
ACTIVENET_API_KEY_US=your-activenet-us-key
# ActiveNet US secret.
# secret
ACTIVENET_SECRET_US=your-activenet-us-secret
# ActiveNet Canada API key.
# secret
ACTIVENET_API_KEY_CA=your-activenet-ca-key
# ActiveNet Canada secret.
# secret
ACTIVENET_SECRET_CA=your-activenet-ca-secret
# Google Places key for provider search fallback.
# secret
GOOGLE_PLACES_API_KEY=your-google-api-key
# IP geolocation key for get-user-location fallback.
# secret
IPAPI_KEY=your-ipapi-key

# AI
# OpenAI API key for orchestration and extraction.
# secret
OPENAI_API_KEY=sk-your-openai-key
# Default OpenAI model for orchestration.
OPENAI_MODEL=gpt-4o
# Default OpenAI temperature for orchestration.
OPENAI_TEMPERATURE=0.3
# Vision model for program extraction.
OPENAI_MODEL_PROGRAM_VISION=gpt-5-vision-preview
# Extractor model for program extraction.
OPENAI_MODEL_PROGRAM_EXTRACTOR=gpt-5.1
# Validator model for program extraction.
OPENAI_MODEL_PROGRAM_VALIDATOR=gpt-5.1-mini
# Token served for OpenAI ChatGPT App submission verification.
# secret
OPENAI_VERIFICATION_TOKEN=your-openai-verification-token
# Run OpenAI smoke tests during server startup.
RUN_OPENAI_SMOKE_TESTS=false
# AI provider selector.
AI_PROVIDER=openai
# Anthropic API key when AI_PROVIDER=claude.
# secret
ANTHROPIC_API_KEY=your-anthropic-key
# Claude text model when AI_PROVIDER=claude.
CLAUDE_MODEL=claude-sonnet-4-6
# Claude vision model when AI_PROVIDER=claude.
CLAUDE_MODEL_VISION=claude-sonnet-4-6

# Auth
# Auth0 tenant domain for OAuth.
AUTH0_DOMAIN=your-tenant.us.auth0.com
# Auth0 application client ID.
AUTH0_CLIENT_ID=your-auth0-client-id
# Auth0 application client secret.
# secret
AUTH0_CLIENT_SECRET=your-auth0-client-secret
# Auth0 API audience.
AUTH0_AUDIENCE=https://shipworx.ai/api
# OAuth prompt behavior for account switching.
AUTH0_OAUTH_PROMPT=login
# Override OAuth callback URL used in metadata/authorize flows.
OAUTH_DEFAULT_REDIRECT_URI=https://oauth.openai.com/v1/callback

# Mandates and PII
# Base64 signing key for mandate issuance and verification.
# secret
MANDATE_SIGNING_KEY=base64-32-byte-signing-key
# Development-only mandate JWS used by local/test flows.
# secret
DEV_MANDATE_JWS=dev-mandate-jws
# Development-only bypass for mandate verification.
MANDATE_OPTIONAL=false
# Base64 AES-256-GCM key for encrypted PII envelopes.
# secret
PII_ENCRYPTION_KEY=base64-32-byte-encryption-key
# Key identifier stored in encrypted PII envelopes.
PII_ENCRYPTION_KEY_ID=v1
# JSON map of historical PII encryption keys for rotation.
# secret
PII_ENCRYPTION_KEYRING_JSON="{}"
# Credential sealing key used by signup job Edge Functions.
# secret
CRED_SEAL_KEY=your-credential-seal-key
# Setup password for the internal system user Edge Function.
# secret
SYSTEM_USER_PASSWORD=use-a-strong-generated-password

# Worker
# Max time the scheduled worker rapid-retries near open time.
SCHEDULED_WORKER_MAX_ATTEMPT_MS=120000

# Smoke
# Railway web service URL for health smoke checks.
RAILWAY_MCP_URL=https://your-web-service.up.railway.app
# Railway worker service URL for health smoke checks when public/accessible.
RAILWAY_WORKER_URL=https://your-worker-service.up.railway.app
# Fail Railway smoke if worker health URL is missing.
RAILWAY_WORKER_HEALTH_REQUIRED=false

# Worker
# Worker URL used by refresh-feed Edge Function.
WORKER_URL=https://your-worker-service.up.railway.app
# Token used by Edge Functions to call worker-only routes.
# secret
WORKER_SERVICE_TOKEN=your-worker-service-token

# Smoke
# Test user ID for scheduled registration smoke scripts.
E2E_USER_ID=00000000-0000-0000-0000-000000000000
# Explicit opt-in for real worker execution smoke.
E2E_EXECUTE=0
# Minutes until a test scheduled registration is due.
E2E_DUE_IN_MINUTES=2
# Polling interval for v1 watch scripts.
V1_WATCH_POLL_MS=1000
# Timeout for v1 watch scripts.
V1_WATCH_TIMEOUT_MS=600000
# Receipt polling interval for worker E2E smoke.
WORKER_E2E_RECEIPTS_POLL_MS=5000
# Receipt polling timeout for worker E2E smoke.
WORKER_E2E_RECEIPTS_TIMEOUT_MS=600000

# Admin and observability
# Enable /admin/api/* endpoints on the MCP server.
ADMIN_API_ENABLED=false
# Comma-separated admin email allowlist.
# secret
ADMIN_EMAIL_ALLOWLIST=you@example.com
# Recent audit events sampled by admin metrics.
ADMIN_METRICS_SAMPLE_LIMIT=5000
# Enable /admin route in the frontend.
VITE_ADMIN_CONSOLE_ENABLED=false
# Base URL for the admin API.
VITE_ADMIN_API_BASE_URL=https://your-web-service.up.railway.app
# PostHog project link shown in the admin UI.
VITE_POSTHOG_PROJECT_URL=https://app.posthog.com/project/123
# Sentry project link shown in the admin UI.
VITE_SENTRY_PROJECT_URL=https://sentry.io/organizations/example/projects/signupassist
# PostHog project API key for server-side capture.
# secret
POSTHOG_API_KEY=phc_your_key
# PostHog host.
POSTHOG_HOST=https://app.posthog.com
# PostHog network timeout.
POSTHOG_TIMEOUT_MS=1200
# Optional Sentry DSN.
# secret
SENTRY_DSN=https://public@sentry.example/1

# Debug
# Enable scoped debug logging.
DEBUG_LOGGING=false
# Enable MCP refresh debugging.
DEBUG_MCP_REFRESH=false
# Scope debug logging to a single user ID.
DEBUG_USER_ID=00000000-0000-0000-0000-000000000000
# Scope debug logging to a single session ID.
DEBUG_SESSION_ID=debug-session-id
# Expose debug telemetry endpoint.
EXPOSE_TELEMETRY_DEBUG=false
# Token required for debug telemetry access.
# secret
EXPOSE_TELEMETRY_DEBUG_TOKEN=your-debug-token
# Logger verbosity.
LOG_LEVEL=info

# Runtime limits
# Enable MCP HTTP rate limiting.
RATE_LIMIT_ENABLED=true
# Rate-limit window in milliseconds.
RATE_LIMIT_WINDOW_MS=60000
# Max tool calls per rate-limit window.
RATE_LIMIT_TOOLS_MAX=240
# Max messages per rate-limit window.
RATE_LIMIT_MESSAGES_MAX=600
# Max SSE requests per rate-limit window.
RATE_LIMIT_SSE_MAX=240
# Max OAuth token requests per rate-limit window.
RATE_LIMIT_OAUTH_TOKEN_MAX=2000
# Concurrent SSE stream cap per token/IP.
SSE_MAX_ACTIVE=5
# Max /tools/call request body size.
MAX_TOOLS_CALL_BODY_BYTES=262144
# Max /messages request body size.
MAX_MESSAGES_BODY_BYTES=262144
# Max OAuth token request body size.
MAX_OAUTH_TOKEN_BODY_BYTES=65536

# Feature flags
# Enable up-front intent parsing.
FEATURE_INTENT_UPFRONT=true
# Enable parallel program extraction.
FEATURE_PARALLEL_EXTRACT=true
# Enable single-pass program extraction.
FEATURE_SINGLE_PASS=false
# Enable schedule preference filtering.
FEATURE_SCHEDULE_FILTER=true
# Use APIOrchestrator runtime path.
USE_API_ORCHESTRATOR=true
# Call the real MCP server from orchestration code.
USE_REAL_MCP=false
# Enable the newer AAP narrowing system.
USE_NEW_AAP=false
# Enable legacy widget rendering if ever reintroduced.
WIDGET_ENABLED=false
# Enable discovery v2 frontend behavior.
VITE_DISCOVERY_V2_ENABLED=true
# Frontend discovery stage timeout.
VITE_DISCOVERY_MAX_STAGE_SECONDS=60

# VGS
# Enable VGS proxying for tokenization/detokenization.
VGS_PROXY_ENABLED=false
# VGS vault identifier.
# secret
VGS_VAULT_ID=tntxxxxxxxx
# VGS proxy URL.
VGS_PROXY_HOST=https://tntxxxxxxxx.sandbox.verygoodproxy.com
# VGS API username.
# secret
VGS_USERNAME=your-vgs-username
# VGS API password.
# secret
VGS_PASSWORD=your-vgs-password

# Railway runtime
# Railway-provided public domain, used to compute base URLs.
RAILWAY_PUBLIC_DOMAIN=your-web-service.up.railway.app
# Optional deploy-mode flag used by Railway docs/scripts.
RAILWAY_AUTO_DEPLOY=true
