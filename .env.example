# Railway MCP Server URL (required for frontend to call MCP directly)
# Example: https://signupassist-mcp-production.up.railway.app
VITE_MCP_BASE_URL=https://your-railway-app.up.railway.app
RAILWAY_MCP_URL=https://your-web-service.up.railway.app
RAILWAY_WORKER_URL=https://your-worker-service.up.railway.app
RAILWAY_WORKER_HEALTH_REQUIRED=false

# MCP Access Token (required for authenticated tool calls)
VITE_MCP_ACCESS_TOKEN=your-mcp-access-token-here
MCP_SERVER_URL=https://your-web-service.up.railway.app
MCP_ACCESS_TOKEN=your-mcp-access-token-here

# Supabase frontend client
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_SMOKE_FUNCTIONS=get-user-location

# Stripe billing
# STRIPE_AUTOPILOT_PRICE_ID is optional. If omitted, the subscription checkout
# function creates a $9/month Checkout price inline.
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_AUTOPILOT_PRICE_ID=price_signupassist_autopilot_monthly
PUBLIC_SITE_URL=http://localhost:8080

# OpenAI Configuration (for AI Orchestrator)
OPENAI_API_KEY=your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.3

# AI Provider: "openai" (default) or "claude"
AI_PROVIDER=openai

# Anthropic (required if AI_PROVIDER=claude)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MODEL_VISION=claude-sonnet-4-6

# Active.com API Keys
ACTIVE_SEARCH_API_V2_KEY=your-active-search-api-v2-key
ACTIVENET_API_KEY_US=your-activenet-us-key
ACTIVENET_API_KEY_CA=your-activenet-ca-key

# OpenAI Models for Program Extraction (Quick Win #5: PACK-06 compatibility)
OPENAI_MODEL_PROGRAM_VISION=gpt-5-vision-preview
OPENAI_MODEL_PROGRAM_EXTRACTOR=gpt-5.1
OPENAI_MODEL_PROGRAM_VALIDATOR=gpt-5.1-mini

# Feature Flags (Quick Wins #6-7)
FEATURE_INTENT_UPFRONT=true          # Intent parsing enabled (Prompt A is live)
FEATURE_PARALLEL_EXTRACT=true        # Parallel batch processing (p-limit in Pass 2)
FEATURE_SINGLE_PASS=false            # Enable when GPT-5.1 is validated for single-pass extraction

# Orchestrator Mode
# NOTE: APIOrchestrator is the ONLY runtime path now (AIOrchestrator is deprecated).
# This flag is kept only for backwards compatibility / documentation.
USE_API_ORCHESTRATOR=true

# Google Places API (for provider search fallback)
GOOGLE_PLACES_API_KEY=your-google-api-key

# VGS (Very Good Security) Proxy Configuration
# Required for PII tokenization/detokenization
VGS_PROXY_ENABLED=false              # Set to 'true' to enable VGS proxy
VGS_VAULT_ID=tntxxxxxxxx             # Your VGS vault identifier
VGS_PROXY_HOST=https://tntxxxxxxxx.sandbox.verygoodproxy.com  # VGS proxy URL
VGS_USERNAME=your-vgs-username       # VGS API username
VGS_PASSWORD=your-vgs-password       # VGS API password

# OpenAI ChatGPT App Verification
# Get this token from the OpenAI submission form when adding your MCP server URL
OPENAI_VERIFICATION_TOKEN=your-token-from-openai-submission-form
